# Server-side configuration. Put real values in Render secrets or backend/.env;
# never put SUPABASE_SERVICE_ROLE_KEY in the frontend.
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Required Render/server-side secrets for the authenticated private-library flow.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
DATABASE_URL=postgresql://<database-user>:<database-password>@<database-host>:5432/postgres
VECTOR_STORE_TYPE=supabase_pgvector

# Keep these server-side if your deployment uses them.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
LOG_LEVEL=INFO

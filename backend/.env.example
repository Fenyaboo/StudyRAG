# ==============================================================================
# STUDYRAG — ENVIRONMENT CONFIGURATION FILE (.env)
# ==============================================================================

# 1. THIẾT LẬP MÁY CHỦ
APP_ENV="development"
APP_HOST="0.0.0.0"
APP_PORT=8000
FRONTEND_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
LOG_LEVEL="INFO"

# ==============================================================================
# 2. CẤU HÌNH CƠ SỞ DỮ LIỆU & VECTOR STORE (MILESTONE 1 & 2)
# ==============================================================================
# Mặc định chạy Local không cần cài gì (SQLite + JSONL):
DATABASE_URL="sqlite:///./data/studyrag.db"
VECTOR_STORE_TYPE="sqlite_chroma"

# ---> NẾU BẠN MUỐN KẾT NỐI SUPABASE CLOUD (Từ hình chụp của bạn):
# Bạn lấy mật khẩu Database khi tạo project trên Supabase và điền vào đây:
# DATABASE_URL="postgresql://postgres:[MẬT-KHẨU-CỦA-BẠN]@db.yytbytrmkfwerxxeicvu.supabase.co:5432/postgres"
# Hoặc nếu dùng Connection Pooling (Port 6543):
# DATABASE_URL="postgresql://postgres.yytbytrmkfwerxxeicvu:[MẬT-KHẨU-CỦA-BẠN]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"
# VECTOR_STORE_TYPE="supabase_pgvector"

# Các khóa API từ màn hình Connect -> Server của bạn (Dùng cho Supabase Client / Edge):
# SUPABASE_URL="https://yytbytrmkfwerxxeicvu.supabase.co"
# SUPABASE_PUBLISHABLE_KEY="sb_publishable_QOST2giMBGNRWGpRCd_G..."
# SUPABASE_SECRET_KEY="sb_secret_n-rx9..."

# ==============================================================================
# 3. CẤU HÌNH MÔ HÌNH AI & EMBEDDINGS (MILESTONE 2 & 3)
# ==============================================================================
# Mô hình nhúng tiếng Việt chuyên biệt (Bi-encoder):
EMBEDDING_PROVIDER="sentence_transformers"
EMBEDDING_MODEL="bkai-foundation-models/vietnamese-bi-encoder"

# Nhà cung cấp LLM chính (Mặc định: ollama chạy local):
LLM_PROVIDER="ollama"  # Bạn có thể đổi thành "gemini" hoặc "openai"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b" # hoặc llama3.1:8b, gemma2:9b

# ---> NẾU BẠN MUỐN GẮN GOOGLE GEMINI API (Hoặc API từ web AI bên ngoài):
# Chỉ cần điền API Key miễn phí từ Google AI Studio (aistudio.google.com):
# LLM_PROVIDER="gemini"
# GEMINI_API_KEY="AIzaSy[KHÓA-CỦA-BẠN]..."
# GEMINI_MODEL="gemini-1.5-flash"

# ---> HOẶC OPENAI / CÁC API COMPATIBLE KHÁC:
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"
